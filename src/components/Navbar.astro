<nav
  class="fixed top-0 left-0 w-full z-50 bg-black/40 backdrop-blur-xl border-b border-white/5 h-20 flex items-center"
>
  <div class="w-full max-w-7xl mx-auto px-6 flex items-center justify-between">
    <a href="/" class="flex items-center hover:opacity-80 transition-opacity">
      <img
        src="/images/logo_viola.svg"
        alt="DJ"
        class="h-12 w-auto object-contain"
      />
    </a>

    <button
      id="menu-toggle"
      class="flex flex-col gap-1.5 z-50 md:hidden focus:outline-none p-2"
      aria-label="Toggle Menu"
    >
      <span class="w-6 h-0.5 bg-white transition-all duration-300 id-line1"
      ></span>
      <span class="w-6 h-0.5 bg-white transition-all duration-300 id-line2"
      ></span>
      <span class="w-6 h-0.5 bg-white transition-all duration-300 id-line3"
      ></span>
    </button>

    <div
      class="hidden md:flex gap-8 text-sm uppercase tracking-wider text-zinc-300 items-center"
    >
      <a href="#about" class="hover:text-white transition">About</a>
      <a href="#contact" class="hover:text-white transition">Contact</a>
      <a href="#music" class="hover:text-white transition">Music</a>
      <a href="#gallery" class="hover:text-white transition">Gallery</a>
      <img
        src="/images/logo_omino.svg"
        alt="DJ"
        class="h-12 w-12 rounded-full border border-white/10 object-cover"
      />
    </div>
  </div>
</nav>

<div
  id="mobile-menu"
  class="fixed inset-0 bg-zinc-950 flex flex-col items-center justify-center gap-8 text-xl uppercase tracking-widest text-zinc-300 opacity-0 pointer-events-none transition-all duration-300 md:hidden z-40"
>
  <div class="pt-12 flex flex-col items-center gap-8 w-full">
    <a
      href="#about"
      class="mobile-link hover:text-white transition-colors duration-200"
      >About</a
    >
    <a
      href="#contact"
      class="mobile-link hover:text-white transition-colors duration-200"
      >Contatti</a
    >
    <a
      href="#music"
      class="mobile-link hover:text-white transition-colors duration-200"
      >Playlist</a
    >
    <a
      href="#gallery"
      class="mobile-link hover:text-white transition-colors duration-200"
      >Galleria</a
    >

    <div class="mt-4 flex justify-center">
      <img
        src="/images/logo_omino.svg"
        alt="DJ Logo"
        class="h-44 w-auto object-contain opacity-90"
      />
    </div>
    <p class="text-xs text-zinc-400">Created by Shhte &copy</p>
  </div>
</div>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileLinks = document.querySelectorAll(".mobile-link");
  const line1 = document.querySelector(".id-line1");
  const line2 = document.querySelector(".id-line2");
  const line3 = document.querySelector(".id-line3");

  function toggleMenu() {
    mobileMenu?.classList.toggle("opacity-0");
    mobileMenu?.classList.toggle("pointer-events-none");
    // Animazione hamburger -> X
    line1?.classList.toggle("rotate-45");
    line1?.classList.toggle("translate-y-2");
    line2?.classList.toggle("opacity-0");
    line3?.classList.toggle("-rotate-45");
    line3?.classList.toggle("-translate-y-2");
  }

  menuToggle?.addEventListener("click", toggleMenu);
  mobileLinks.forEach((link) => link.addEventListener("click", toggleMenu));
</script>
