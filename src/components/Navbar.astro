<script>
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileLinks = document.querySelectorAll(".mobile-link");
  const line1 = document.querySelector(".id-line1");
  const line2 = document.querySelector(".id-line2");
  const line3 = document.querySelector(".id-line3");

  function toggleMenu() {
    mobileMenu?.classList.toggle("opacity-0");
    mobileMenu?.classList.toggle("pointer-events-none");
    // Animazione hamburger -> X
    line1?.classList.toggle("rotate-45");
    line1?.classList.toggle("translate-y-2");
    line2?.classList.toggle("opacity-0");
    line3?.classList.toggle("-rotate-45");
    line3?.classList.toggle("-translate-y-2");
  }

  menuToggle?.addEventListener("click", toggleMenu);
  mobileLinks.forEach((link) => link.addEventListener("click", toggleMenu));

  // Gestione tema
  const sunIcons = document.querySelectorAll(
    "#theme-toggle-sun, #theme-toggle-sun-mobile",
  );
  const moonIcons = document.querySelectorAll(
    "#theme-toggle-moon, #theme-toggle-moon-mobile",
  );
  const themeToggles = document.querySelectorAll(
    "#theme-toggle, #theme-toggle-mobile",
  );

  function updateIcons(currentTheme: string) {
    if (currentTheme === "light") {
      sunIcons.forEach((icon) => icon.classList.add("hidden"));
      moonIcons.forEach((icon) => icon.classList.remove("hidden"));
    } else {
      sunIcons.forEach((icon) => icon.classList.remove("hidden"));
      moonIcons.forEach((icon) => icon.classList.add("hidden"));
    }
  }

  // Inizializza icone
  const initialTheme =
    document.documentElement.getAttribute("data-theme") || "dark";
  updateIcons(initialTheme);

  themeToggles.forEach((toggle) => {
    toggle.addEventListener("click", () => {
      const currentTheme =
        document.documentElement.getAttribute("data-theme") || "dark";
      const nextTheme = currentTheme === "light" ? "dark" : "light";

      document.documentElement.setAttribute("data-theme", nextTheme);
      localStorage.setItem("theme", nextTheme);
      updateIcons(nextTheme);
    });
  });
</script>
