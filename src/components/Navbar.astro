<nav class="fixed top-0 left-0 w-full z-50 backdrop-blur-xl bg-black/30 border-b border-white/5">  
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    

    <img
      src="/images/logo_white.svg"
      alt="DJ"
      class="rounded-3xl h-[80px]"
    />


    <button id="menu-toggle" class="flex flex-col gap-1.5 z-50 md:hidden focus:outline-none" aria-label="Toggle Menu">
      <span class="w-6 h-0.5 bg-white transition-transform duration-300 id-line1"></span>
      <span class="w-6 h-0.5 bg-white transition-opacity duration-300 id-line2"></span>
      <span class="w-6 h-0.5 bg-white transition-transform duration-300 id-line3"></span>
    </button>

    <div class="hidden md:flex gap-8 text-sm uppercase tracking-wider text-zinc-300">
      <a href="#about" class="hover:text-white transition">About</a>
      <a href="#contact" class="hover:text-white transition">Contact</a>
      <a href="#music" class="hover:text-white transition">Music</a>
      <a href="#gallery" class="hover:text-white transition">Gallery</a>
    </div>

    <div id="mobile-menu" class="fixed inset-0 bg-black/95 backdrop-blur-2xl flex flex-col items-center justify-center gap-8 text-xl uppercase tracking-widest text-zinc-300 opacity-0 pointer-events-none transition-all duration-300 md:hidden mt-40">
      <a href="#about" class="mobile-link hover:text-white transition">About</a>
      <a href="#contact" class="mobile-link hover:text-white transition">Contact</a>
      <a href="#music" class="mobile-link hover:text-white transition">Music</a>
      <a href="#gallery" class="mobile-link hover:text-white transition">Gallery</a>
    </div>

  </div>
</nav>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-link');
  const line1 = document.querySelector('.id-line1');
  const line2 = document.querySelector('.id-line2');
  const line3 = document.querySelector('.id-line3');

  function toggleMenu() {
    mobileMenu?.classList.toggle('opacity-0');
    mobileMenu?.classList.toggle('pointer-events-none');
    // Animazione hamburger -> X
    line1?.classList.toggle('rotate-45');
    line1?.classList.toggle('translate-y-2');
    line2?.classList.toggle('opacity-0');
    line3?.classList.toggle('-rotate-45');
    line3?.classList.toggle('-translate-y-2');
  }

  menuToggle?.addEventListener('click', toggleMenu);
  mobileLinks.forEach(link => link.addEventListener('click', toggleMenu));
</script>