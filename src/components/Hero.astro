---

<!-- Cornice UI Perimetrale (Effetto Applicazione Premium) --><!-- Main Experience Section -->
<section
  class="relative min-h-screen w-full bg-[#05020a] flex flex-col items-center justify-center overflow-hidden p-6"
>
  <!-- Sfondo: Bagliore e Griglia Tech Microscopica -->
  <div
    class="absolute w-[600px] h-[600px] bg-purple-600/10 rounded-full blur-[140px] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none"
  >
  </div>
  <div
    class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff03_1px,transparent_1px),linear-gradient(to_bottom,#ffffff03_1px,transparent_1px)] bg-[size:40px_40px] opacity-10"
  >
  </div>

  <!-- Contenitore Centrale Principale -->
  <div
    class="relative flex flex-col items-center justify-center z-10 w-full max-w-4xl text-center"
  >
    <!-- L'Avatar al Centro (Rivisitato con Glassmorphism Radiale) -->
    <div class="relative group cursor-pointer mb-10">
      <!-- Glow Dinamico Interattivo al Passaggio del Mouse -->
      <div
        class="absolute inset-0 bg-gradient-to-tr from-purple-500 to-indigo-500 rounded-full blur-3xl opacity-20 group-hover:opacity-40 transition-opacity duration-700"
      >
      </div>

      <!-- Cerchio Esterno in Vetro Acrilico Sottile -->
      <div
        class="relative w-72 h-72 sm:w-96 sm:h-96 rounded-full border border-white/10 bg-gradient-to-b from-white/[0.06] to-transparent p-6 backdrop-blur-xl shadow-[0_0_50px_rgba(0,0,0,0.8)] flex items-center justify-center transition-all duration-500 group-hover:border-white/20 group-hover:scale-[1.02]"
      >
        <!-- Cerchio Interno di Contrasto -->
        <div
          class="w-full h-full rounded-full bg-black/40 border border-white/5 p-4 flex items-center justify-center overflow-hidden"
        >
          <img
            src="images/logo_viola.svg"
            alt="DJ Shhte Character"
            class="w-[90%] h-[95%] object-contain transform group-hover:scale-105 transition-transform duration-700 ease-out"
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Footer Info / Scroll Indicator -->
  <div
    class="absolute bottom-8 left-0 w-full px-8 md:px-16 flex justify-between items-center z-10 text-[10px] font-mono tracking-widest text-zinc-600 hidden sm:flex"
  >
    <div>[ 45.4642° N, 9.1900° E ]</div>
    <div class="flex items-center gap-2">
      <span class="w-12 h-[1px] bg-zinc-800 inline-block"></span>
      <span>SCROLL TO ENTER</span>
    </div>
    <div>© 2026 ALL RIGHTS RESERVED</div>
  </div>
</section>
