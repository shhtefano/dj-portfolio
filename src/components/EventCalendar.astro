---
interface Event {
  date: string; // ISO format: "YYYY-MM-DD"
  venue: string;
  city: string;
  time: string; // e.g. "23:00"
  type: "main" | "support" | "b2b";
  ticketUrl?: string;
}

const events: Event[] = [
  {
    date: "2026-06-21",
    venue: "Maracaibo",
    city: "Cava d'aliga",
    time: "17:00",
    type: "main",
  },
  {
    date: "2026-07-19",
    venue: "Maracaibo",
    city: "Cava d'aliga",
    time: "17:00",
    type: "main",
  },
  {
    date: "2026-08-16",
    venue: "Maracaibo",
    city: "Cava d'aliga",
    time: "17:00",
    type: "main",
  },
  {
    date: "2026-07-26",
    venue: "Thyme",
    city: "Randello",
    time: "17:00",
    type: "main",
  },
];

// Helper to prevent UTC offset issues when parsing "YYYY-MM-DD" dates
const parseDate = (dateStr: string) => {
  const [year, month, day] = dateStr.split("-").map(Number);
  return new Date(year, month - 1, day);
};

// Sort ascending
const sorted = [...events].sort(
  (a, b) => parseDate(a.date).getTime() - parseDate(b.date).getTime(),
);

// Group by month label
const grouped: Record<string, Event[]> = {};
for (const ev of sorted) {
  const d = parseDate(ev.date);
  const key = d.toLocaleDateString("it-IT", { month: "long", year: "numeric" });
  if (!grouped[key]) grouped[key] = [];
  grouped[key].push(ev);
}

const typeLabel: Record<Event["type"], string> = {
  main: "Main",
  support: "Support",
  b2b: "B2B",
};

const typeColor: Record<Event["type"], string> = {
  main: "var(--purple)",
  support: "var(--orange)",
  b2b: "var(--cyan)",
};
---

<section class="calendar" id="dates">
  <p class="eyebrow">DATES</p>
  <h2 class="section-title">LIVE.<span class="dot">_</span></h2>

  <div class="months">
    {
      Object.entries(grouped).map(([month, evs]) => (
        <div class="month-block">
          <h3 class="month-label">{month.toUpperCase()}</h3>
          <ul class="event-list">
            {evs.map((ev) => {
              const d = parseDate(ev.date);
              const dayNum = d.toLocaleDateString("it-IT", { day: "2-digit" });
              const dayName = d
                .toLocaleDateString("it-IT", { weekday: "short" })
                .toUpperCase();
              return (
                <li class="event-row">
                  {/* Date block */}
                  <div class="date-block">
                    <span class="day-num">{dayNum}</span>
                    <span class="day-name">{dayName}</span>
                  </div>

                  {/* Divider line */}
                  <div class="divider" />

                  {/* Info */}
                  <div class="event-info">
                    <span class="venue">{ev.venue}</span>
                    <span class="city-time">
                      {ev.city} &mdash; {ev.time}
                    </span>
                  </div>

                  {/* Type badge */}
                  <span
                    class="type-badge"
                    style={`color: ${typeColor[ev.type]}; border-color: ${typeColor[ev.type]};`}
                  >
                    {typeLabel[ev.type]}
                  </span>

                  {/* Ticket/Availability (5th column) */}
                  {ev.ticketUrl ? (
                    <a
                      href={ev.ticketUrl}
                      class="ticket-btn"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      TICKETS
                    </a>
                  ) : (
                    <span class="sold-out">FREE</span>
                  )}
                </li>
              );
            })}
          </ul>
        </div>
      ))
    }
  </div>
</section>

<style>
  /* ── Tokens (mirror your existing site palette) ── */
  :root {
    --cyan: #00d4ff;
    --orange: #f5a623;
    --purple: #c86dd7;
    --white: #ffffff;
    --muted: #6b6b6b;
    --bg: #000000;
    --border: #1c1c1c;
    --font-display: "Arial Black", "Impact", sans-serif;
    --font-body: "Arial", sans-serif;
  }

  /* ── Section shell ── */
  .calendar {
    background: var(--bg);
    color: var(--white);
    padding: 8rem 2rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .eyebrow {
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: 0.25em;
    color: var(--muted);
    margin: 0 0 0.75rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 7vw, 5rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    margin: 0 0 3.5rem;
    text-transform: uppercase;
    color: var(--white);
  }

  .dot {
    color: var(--cyan);
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  /* ── Month grouping ── */
  .months {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .month-label {
    font-family: var(--font-body);
    font-size: 0.9rem;
    letter-spacing: 0.2em;
    color: cyan;
    margin: 0 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  /* ── Event rows ── */
  .event-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .event-row {
    display: grid;
    grid-template-columns: 3.5rem 1px 1fr auto auto;
    align-items: center;
    gap: 1.25rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
    transition: background 0.18s ease;
    cursor: default;
  }

  .event-row:hover {
    background: rgba(255, 255, 255, 0.03);
    border-radius: 4px;
  }

  /* Date block */
  .date-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1;
  }

  .day-num {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--white);
  }

  .day-name {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    color: var(--muted);
    margin-top: 2px;
  }

  /* Divider */
  .divider {
    width: 1px;
    height: 2.2rem;
    background: var(--border);
    flex-shrink: 0;
  }

  /* Event info */
  .event-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .venue {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--white);
  }

  .city-time {
    font-size: 0.72rem;
    color: var(--muted);
    letter-spacing: 0.08em;
  }

  /* Type badge */
  .type-badge {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    border: 1px solid;
    border-radius: 2px;
    padding: 0.2em 0.55em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  /* Ticket button */
  .ticket-btn {
    font-family: var(--font-display);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    color: var(--bg);
    background: var(--cyan);
    padding: 0.4em 0.85em;
    text-decoration: none;
    border-radius: 2px;
    white-space: nowrap;
    transition:
      opacity 0.15s ease,
      transform 0.15s ease;
  }

  .ticket-btn:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .sold-out {
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    color: var(--muted);
    white-space: nowrap;
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .event-row {
      grid-template-columns: 3rem 1px 1fr;
      grid-template-rows: auto auto;
      row-gap: 0.5rem;
    }

    .type-badge,
    .ticket-btn,
    .sold-out {
      grid-column: 3;
    }

    .ticket-btn {
      display: inline-block;
      width: fit-content;
    }
  }
</style>
