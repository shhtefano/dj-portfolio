---
interface Event {
  date: string; // ISO format: "YYYY-MM-DD"
  venue: string;
  city: string;
  time: string; // e.g. "23:00"
  type: "main" | "support" | "b2b";
  ticketUrl?: string;
  address?: string;
  websiteUrl?: string;
  mapsUrl?: string;
}

const events: Event[] = [
  {
    date: "2026-06-26",
    venue: "Pata Pata",
    city: "Sampieri",
    time: "17:00",
    type: "b2b",
    address: "Lungomare Sampieri",
    websiteUrl: "https://www.instagram.com/patapata.sampieri/",
    mapsUrl: "https://maps.app.goo.gl/vejmE4knujR85Wf78",
  },
  {
    date: "2026-06-26",
    venue: "Miscele",
    city: "Scicli",
    time: "23:00",
    type: "main",
    address: "Piazza Busacca",
    websiteUrl: "https://www.instagram.com/miscele_cocktail_bar/",
    mapsUrl: "https://maps.app.goo.gl/3eqJtAqc4HeqFFt99",
  },
  {
    date: "2026-07-05",
    venue: "Maracaibo",
    city: "Cava d'Aliga",
    time: "17:00",
    type: "main",
    address: "Lungomare Cava d'Aliga",
    websiteUrl: "https://www.instagram.com/ristorantemaracaibo/",
    mapsUrl: "https://maps.app.goo.gl/CETLFBHsZ1d8WPwA7",
  },
  {
    date: "2026-08-02",
    venue: "Thyme",
    city: "Randello",
    time: "17:00",
    type: "main",
    address: "SP85, Ragusa",
    websiteUrl: "https://thymebeach.com/",
    mapsUrl: "https://maps.app.goo.gl/SCgLYZgAS8ahxqQ86",
  },
];

const parseDate = (dateStr: string) => {
  const [year, month, day] = dateStr.split("-").map(Number);
  return new Date(year, month - 1, day);
};

const sorted = [...events].sort(
  (a, b) => parseDate(a.date).getTime() - parseDate(b.date).getTime(),
);

const grouped: Record<string, Event[]> = {};
for (const ev of sorted) {
  const d = parseDate(ev.date);
  const key = d.toLocaleDateString("it-IT", { month: "long", year: "numeric" });
  if (!grouped[key]) grouped[key] = [];
  grouped[key].push(ev);
}

const typeLabel: Record<Event["type"], string> = {
  main: "Main",
  support: "Support",
  b2b: "B2B",
};

const typeColor: Record<Event["type"], string> = {
  main: "var(--purple)",
  support: "var(--orange)",
  b2b: "var(--purple)",
};
---

<section class="calendar" id="dates">
  <h2 class="section-title md:px-34">CALENDARIO<span class="dot">_</span></h2>

  <div class="months md:px-34 xs:p-0">
    {
      Object.entries(grouped).map(([month, evs]) => (
        <div class="month-block">
          <h3 class="month-label">{month.toUpperCase()}</h3>
          <ul class="event-list">
            {evs.map((ev) => {
              const d = parseDate(ev.date);
              const dayNum = d.toLocaleDateString("it-IT", { day: "2-digit" });
              const dayName = d
                .toLocaleDateString("it-IT", { weekday: "short" })
                .toUpperCase();
              return (
                <li class="event-row">
                  {/* Blocco Data (Colonna Sinistra fissa) */}
                  <div class="date-side">
                    <div class="date-block">
                      <span class="day-num">{dayNum}</span>
                      <span class="day-name">{dayName}</span>

                      {/* Mobile-only tags directly under the date */}
                      <div class="event-actions mobile-actions">
                        <span
                          class="type-badge"
                          style={`color: ${typeColor[ev.type]}; border-color: ${typeColor[ev.type]};`}
                        >
                          {typeLabel[ev.type]}
                        </span>

                        {ev.ticketUrl ? (
                          <a
                            href={ev.ticketUrl}
                            class="ticket-btn"
                            target="_blank"
                            rel="noopener noreferrer"
                          >
                            TICKETS
                          </a>
                        ) : (
                          <span class="sold-out">FREE</span>
                        )}
                      </div>
                    </div>
                    <div class="divider mr-8" />
                  </div>

                  {/* Blocco Contenuto Informativo (Allineamento Geometrico) */}
                  <div class="content-side">
                    <div class="event-info">
                      <span class="venue">{ev.venue}</span>
                      <span class="city-time">
                        {ev.city} &mdash; {ev.time}
                      </span>
                    </div>

                    <div class="event-address">
                      {ev.address && (
                        <span class="address-text">{ev.address}</span>
                      )}
                      {ev.mapsUrl && (
                        <a
                          href={ev.mapsUrl}
                          class="maps-link"
                          target="_blank"
                          rel="noopener noreferrer"
                          title="Open in Google Maps"
                        >
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="maps-icon"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          >
                            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                            <circle cx="12" cy="10" r="3" />
                          </svg>
                        </a>
                      )}
                    </div>

                    <div class="event-website">
                      {ev.websiteUrl && (
                        <a
                          href={ev.websiteUrl}
                          class="website-link"
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          WEBSITE
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="web-icon"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          >
                            <path d="M15 3h6v6" />
                            <path d="M10 14 21 3" />
                            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                          </svg>
                        </a>
                      )}
                    </div>

                    {/* Badge e Azioni (Desktop only, hidden on mobile) */}
                    <div class="event-actions desktop-actions">
                      <span
                        class="type-badge"
                        style={`color: ${typeColor[ev.type]}; border-color: ${typeColor[ev.type]};`}
                      >
                        {typeLabel[ev.type]}
                      </span>

                      {ev.ticketUrl ? (
                        <a
                          href={ev.ticketUrl}
                          class="ticket-btn"
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          TICKETS
                        </a>
                      ) : (
                        <span class="sold-out">FREE</span>
                      )}
                    </div>
                  </div>
                </li>
              );
            })}
          </ul>
        </div>
      ))
    }
  </div>
</section>

<style>
  /* ── Palette & Tokens ── */
  :root {
    --orange: #f5a623;
    --purple: #8f00ff;
    --white: #ffffff;
    --muted: #6b6b6b;
    --bg: #000000;
    --border: #1c1c1c;
    --font-display: "Arial Black", "Impact", sans-serif;
    --font-body: "Arial", sans-serif;
  }

  /* ── Layout Contenitore ── */
  .calendar {
    background: var(--bg);
    color: var(--white);
    padding: 12rem 2rem 2rem 2rem;
    width: 100%;
  }

  .eyebrow {
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: 0.25em;
    color: var(--muted);
    margin: 0 0 0.75rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 7vw, 5rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    margin: 0 0 3.5rem;
    text-transform: uppercase;
  }

  .dot {
    color: var(--purple);
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  .months {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .month-label {
    font-family: var(--font-body);
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    color: white;
    font-weight: 500;
    padding-left: 0.7rem;
    font-style: bold;
    /* border-bottom: 1px solid var(--border); */
  }

  .event-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  /* ── Struttura Riga (Desktop Layout) ── */
  .event-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 4rem;
    padding: 2rem 0;
    border-bottom: 1px solid var(--border);
    transition: background 0.18s ease;
  }

  .event-row:hover {
    background: rgba(255, 255, 255, 0.02);
  }

  /* Blocco Sinistro: Data + Linea */
  .date-side {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-shrink: 0;
  }

  .date-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 4.5rem;
    line-height: 1;
  }

  .day-num {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 900;
    color: #6c00b4;
  }

  .day-name {
    font-size: 1rem;
    letter-spacing: 0.12em;
    margin-top: 4px;
  }

  .divider {
    width: 1px;
    height: 2.2rem;
    background: var(--border);
  }

  /* Blocco Destro: Info a sinistra, Azioni a destra */
  .content-side {
    display: grid;
    grid-template-columns: 1.8fr 2.2fr 1.2fr 1.8fr;
    align-items: center;
    gap: 1.5rem;
    flex-grow: 1;
    padding-left: 0.5rem;
  }

  .event-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .venue {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .city-time {
    font-size: 0.75rem;
    color: #c7c7c7;
    letter-spacing: 0.05em;
  }

  .event-address {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--muted);
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    min-width: 0;
  }

  .address-text {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .maps-link {
    color: var(--white);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition:
      color 0.15s ease,
      transform 0.15s ease;
    flex-shrink: 0;
  }

  .maps-link:hover {
    color: var(--purple);
    transform: translateY(-1px);
  }

  .maps-icon {
    width: 0.7rem;
    height: 0.7rem;
  }

  .event-website {
    display: flex;
    align-items: center;
    min-width: 0;
  }

  .website-link {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 900;
    color: var(--white);
    text-decoration: underline;
    letter-spacing: 0.1em;
    display: inline-flex;
    align-items: center;
    transition: color 0.15s ease;
    white-space: nowrap;
  }

  .website-link:hover {
    color: var(--purple);
  }

  .web-icon {
    width: 0.55rem;
    height: 0.55rem;
    margin-left: 0.25rem;
    display: inline-block;
    vertical-align: middle;
  }

  /* Wrapper Azioni (Badge + Bottone) */
  .event-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .mobile-actions {
    display: none;
  }

  .type-badge {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    border: 1px solid;
    border-radius: 2px;
    padding: 0.25em 0.6rem;
    text-transform: uppercase;
    white-space: nowrap;
    line-height: 1;
  }

  .ticket-btn {
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    color: var(--bg);
    background: var(--purple);
    padding: 0.45em 0.9em;
    text-decoration: none;
    border-radius: 2px;
    white-space: nowrap;
    transition: opacity 0.15s ease;
  }

  .ticket-btn:hover {
    opacity: 0.85;
  }

  .sold-out {
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    color: var(--muted);
    white-space: nowrap;
    font-weight: 700;
  }

  /* ── RIPRISTINO TOTALE MOBILE (Sotto i 600px) ── */
  @media (max-width: 600px) {
    .event-row {
      align-items: flex-start; /* Allinea in alto rispetto alla data */
      padding: 2rem 0.5rem;
      gap: 2rem;
    }

    /* Forza il contenuto principale a scendere in colonna perfettamente squadrato */
    .content-side {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-start;
      gap: 0.65rem; /* Distanza matematica fissa */
      padding-left: 0;
    }

    .event-info {
      align-items: flex-start;
    }

    .event-address {
      white-space: normal;
      word-break: break-word;
    }

    .address-text {
      white-space: normal;
    }

    .desktop-actions {
      display: none !important;
    }

    .mobile-actions {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.45rem;
      width: 100%;
      margin-top: 0.75rem;
    }

    .divider {
      display: none;
    }

    .month-label {
      font-size: 1.1rem;
      font-weight: 700;
    }
  }
</style>
