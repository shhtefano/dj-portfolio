---
import fs from "node:fs";
import path from "node:path";

import MainLayout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Music from "../components/Music.astro";
import Player from "../components/Player.jsx";
import Gallery from "../components/Gallery.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import EventCalendar from "../components/EventCalendar.astro";

interface Track {
  id: string;
  title: string;
  artist: string;
  src: string;
}

// Inizializziamo l'oggetto con tipo 'any' per evitare errori TypeScript
let tracksData: any = {
  previews: [],
  beats: [],
};

// 1. NUOVI PERCORSI (Puntano a public/music/...)
const baseTracksDir = path.join(process.cwd(), "public", "music");
const prodDir = path.join(baseTracksDir, "Tracks"); // Lettera 'T' maiuscola come la tua cartella
const beatsDir = path.join(baseTracksDir, "Beats"); // Lettera 'B' maiuscola come la tua cartella

const getTracksFromFolder = (
  folderPath: string,
  subFolderUrl: string,
): Track[] => {
  if (fs.existsSync(folderPath)) {
    try {
      const files = fs.readdirSync(folderPath);
      return files
        .filter((file) => file.endsWith(".mp3"))
        .map((file, index) => {
          const title = path.parse(file).name;
          return {
            id: `${subFolderUrl}-${index + 1}`,
            title: title,
            artist: "Shhte",
            src: `/music/${subFolderUrl}/${file}`,
          };
        });
    } catch (error) {
      console.error(
        `Errore durante la lettura della cartella ${folderPath}:`,
        error,
      );
    }
  } else {
    console.warn(`Attenzione: La cartella ${folderPath} non esiste sul disco.`);
  }
  return [];
};

tracksData.previews = getTracksFromFolder(prodDir, "Tracks");
tracksData.beats = getTracksFromFolder(beatsDir, "Beats");

const hasTracks = tracksData.previews.length > 0 || tracksData.beats.length > 0;
---

<MainLayout title="SHHTE">
  <Navbar />

  <Hero client:load />

  <About />

  <EventCalendar />
  <Contact />

  {hasTracks && <Player tracks={tracksData} client:load />}

  <Music />

  <Gallery />

  <Footer />
</MainLayout>
